NODE_ENV=development
PORT=3333
# Postgres (Supabase): Connect no dashboard.
#
# Vercel / serverless (IPv4): a URI "direct" db.*.supabase.co:5432 é IPv6 e o build na Vercel falha (P1001).
# Use Transaction pooler na DATABASE_URL e Session pooler na DIRECT_URL (ambas no modal Connect).
#
# DATABASE_URL — Transaction mode (porta 6543), com prepared statements desligados no Prisma:
# postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#
# DIRECT_URL — Migrações: Session mode (host pooler, porta 5432) OU a mesma URI direct se o teu PC alcança IPv6:
# postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
#
# Em dev local com só "direct" a funcionar, podes repetir a mesma string em DATABASE_URL e DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
REDIS_URL=
JWT_SECRET=altere-em-producao
# Em dev, cria teste@local.dev / teste123 se nao existir. Use SEED_DEMO_USER=0 para desligar.
SEED_DEMO_USER=
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
FRONTEND_URL=http://localhost:3000
META_REDIRECT_URI=http://localhost:3333/auth/meta/callback
META_APP_ID=
META_APP_SECRET=
# Se /me/accounts vier vazio: tentar GET /{page-id} com o token de utilizador
META_OAUTH_FALLBACK_PAGE_IDS=
# Último recurso: token da Página (Explorador Graph) + IDs — conclui OAuth sem listagem
META_OAUTH_FALLBACK_PAGE_ID=
META_OAUTH_FALLBACK_PAGE_ACCESS_TOKEN=
META_OAUTH_FALLBACK_IG_USER_ID=
META_VERIFY_TOKEN=dev_verify_token
META_ACCESS_TOKEN=
IG_USER_ID=
PAGE_ID=
