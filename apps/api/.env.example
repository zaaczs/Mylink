NODE_ENV=development
PORT=3333
# Local (SQLite). Na Vercel: crie a mesma variável em Settings → Environment Variables.
# Em produção serverless não use ficheiro local; use Postgres (Neon, Supabase, etc.) e altere `provider` em prisma/schema.prisma.
DATABASE_URL="file:./dev.db"
REDIS_URL=
JWT_SECRET=altere-em-producao
# Em dev, cria teste@local.dev / teste123 se nao existir. Use SEED_DEMO_USER=0 para desligar.
SEED_DEMO_USER=
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
FRONTEND_URL=http://localhost:3000
META_REDIRECT_URI=http://localhost:3333/auth/meta/callback
META_APP_ID=
META_APP_SECRET=
# Se /me/accounts vier vazio: tentar GET /{page-id} com o token de utilizador
META_OAUTH_FALLBACK_PAGE_IDS=
# Último recurso: token da Página (Explorador Graph) + IDs — conclui OAuth sem listagem
META_OAUTH_FALLBACK_PAGE_ID=
META_OAUTH_FALLBACK_PAGE_ACCESS_TOKEN=
META_OAUTH_FALLBACK_IG_USER_ID=
META_VERIFY_TOKEN=dev_verify_token
META_ACCESS_TOKEN=
IG_USER_ID=
PAGE_ID=
